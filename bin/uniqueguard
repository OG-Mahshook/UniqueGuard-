# License: MIT
# Version: 1.2.0
# =====================================================================

CONFIG_FILE="/etc/uniqueguard/uniqueguard.conf"
if [ ! -f "$CONFIG_FILE" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    CONFIG_FILE="${SCRIPT_DIR}/../config/uniqueguard.conf"
fi

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Crystal Clear ASCII Banner for UNIQUE GUARD
print_banner() {
    echo -e "${CYAN}${BOLD}"
    echo '  _   _ _   _ ___ _____  _   _ _____    ____ _   _    _    ____  ____  '
    echo ' | | | | \ | |_ _|  _  || | | | ____|  / ___| | | |  / \  |  _ \|  _ \ '
    echo ' | | | |  \| || || | | || | | |  _|   | |  _| | | | / _ \ | |_) | | | |'
    echo ' | |_| | |\  || || |_| || |_| | |___  | |_| | |_| |/ ___ \|  _ <| |_| |'
    echo '  \___/|_| \_|___|\____\_\___/|_____|  \____|\___//_/   \_\_| \_\____/ '
    echo -e "       ${YELLOW}Advanced VPS/VDS Firewall & Pterodactyl Anti-DDoS Shield${NC}"
    echo -e "          ${GREEN}Copyright (c) 2026 mr-unique | Open Source (MIT)${NC}\n"
}

# Check Root Privileges
check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[ERROR] UNIQUE GUARD requires root privileges.${NC}"
        echo -e "Please run with ${YELLOW}sudo uniqueguard <command>${NC} or as root user."
        exit 1
    fi
}

# Load Configuration File
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
    else
        echo -e "${RED}[ERROR] Configuration file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
}

# Check Dependencies
check_dependencies() {
    if ! command -v iptables &>/dev/null; then
        echo -e "${RED}[ERROR] iptables is missing. Please install iptables.${NC}"
        exit 1
    fi
}

# Send Discord Webhook Alert
send_discord_alert() {
    local title="$1"
    local message="$2"
    local color="${3:-15158332}" # Default Red

    if [ "$ENABLE_DISCORD_ALERTS" = "true" ] && [ -n "$DISCORD_WEBHOOK_URL" ] && command -v curl &>/dev/null; then
        local payload=$(cat <<EOF
{
  "embeds": [
    {
      "title": "🛡️ UNIQUE GUARD Alert: ${title}",
      "description": "${message}",
      "color": ${color},
      "footer": {
        "text": "UNIQUE GUARD Firewall by mr-unique"
      },
      "timestamp": "$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
    }
  ]
}
EOF
)
        curl -s -H "Content-Type: application/json" -X POST -d "$payload" "$DISCORD_WEBHOOK_URL" &>/dev/null || true
    fi
}

# Setup Custom iptables Chains
setup_chains() {
    iptables -N UG_INPUT 2>/dev/null || iptables -F UG_INPUT
    iptables -N UG_DDOS 2>/dev/null || iptables -F UG_DDOS
    iptables -N UG_LOG 2>/dev/null || iptables -F UG_LOG

    if ! iptables -C INPUT -j UG_INPUT 2>/dev/null; then
        iptables -I INPUT 1 -j UG_INPUT
    fi
}

# Apply Main Firewall Rules
start_firewall() {
    print_banner
    check_root
    load_config
    check_dependencies

    echo -e "${BLUE}[*] Initializing UNIQUE GUARD Firewall Engine...${NC}"

    # Set Default Policies safely
    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT

    # Flush & Setup Custom Chain
    setup_chains

    # 1. Allow Loopback (localhost)
    iptables -A UG_INPUT -i lo -j ACCEPT

    # 2. Allow Established and Related Connections
    iptables -A UG_INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

    # 3. Drop Invalid Packets
    if [ "$DROP_INVALID_PACKETS" = "true" ]; then
        echo -e "${YELLOW}  [+] Enabling Invalid Connection Filtering...${NC}"
        iptables -A UG_INPUT -m conntrack --ctstate INVALID -j DROP
    fi

    # 4. Stealth Scan & Malformed TCP Packet Protection
    if [ "$DROP_STEALTH_SCANS" = "true" ]; then
        echo -e "${YELLOW}  [+] Enabling Stealth Scan & Malformed TCP Drop Rules...${NC}"
        iptables -A UG_INPUT -p tcp --tcp-flags ALL NONE -j DROP
        iptables -A UG_INPUT -p tcp --tcp-flags ALL ALL -j DROP
        iptables -A UG_INPUT -p tcp --tcp-flags ALL SYN,FIN -j DROP
        iptables -A UG_INPUT -p tcp --tcp-flags ALL FIN -j DROP
        iptables -A UG_INPUT -p tcp --tcp-flags SYN,RST SYN,RST -j DROP
    fi

    # 5. Apply Whitelisted IPs
    if [ -n "$WHITELIST_IPS" ]; then
        echo -e "${YELLOW}  [+] Applying Whitelisted IPs...${NC}"
        for ip in $WHITELIST_IPS; do
            [ -n "$ip" ] && iptables -A UG_INPUT -s "$ip" -j ACCEPT
        done
    fi

    # 6. Apply Dynamic Hostname Whitelist
    if [ -n "$WHITELIST_HOSTNAMES" ]; then
        echo -e "${YELLOW}  [+] Resolving Hostname Whitelists...${NC}"
        for host in $WHITELIST_HOSTNAMES; do
            resolved_ip=$(getent ahosts "$host" | awk '{print $1}' | head -n 1)
            if [ -n "$resolved_ip" ]; then
                echo -e "      - Whitelisted host ${GREEN}$host${NC} ($resolved_ip)"
                iptables -A UG_INPUT -s "$resolved_ip" -j ACCEPT
            fi
        done
    fi

    # 7. Apply Blacklisted IPs
    if [ -n "$BLACKLIST_IPS" ]; then
        echo -e "${YELLOW}  [+] Applying Blacklisted IPs...${NC}"
        for ip in $BLACKLIST_IPS; do
            [ -n "$ip" ] && iptables -A UG_INPUT -s "$ip" -j DROP
        done
    fi

    # 8. Anti-DDoS Mitigations
    if [ "$ENABLE_ANTI_DDOS" = "true" ]; then
        echo -e "${YELLOW}  [+] Applying Anti-DDoS Defenses...${NC}"

        # TCP SYN Flood Defense
        if [ "$SYN_FLOOD_PROTECTION" = "true" ]; then
            iptables -A UG_INPUT -p tcp --syn -m limit --limit "${SYN_FLOOD_LIMIT:-25/s}" --limit-burst "${SYN_FLOOD_BURST:-50}" -j ACCEPT
            iptables -A UG_INPUT -p tcp --syn -j DROP
        fi

        # UDP Flood Mitigation
        if [ "$UDP_FLOOD_PROTECTION" = "true" ]; then
            iptables -A UG_INPUT -p udp -m limit --limit "${UDP_FLOOD_LIMIT:-60/s}" --limit-burst "${UDP_FLOOD_BURST:-120}" -j ACCEPT
        fi

        # Ping / ICMP Flood Protection
        if [ "$PING_FLOOD_PROTECTION" = "true" ]; then
            iptables -A UG_INPUT -p icmp --icmp-type echo-request -m limit --limit "${PING_LIMIT:-5/s}" --limit-burst "${PING_BURST:-10}" -j ACCEPT
            iptables -A UG_INPUT -p icmp --icmp-type echo-request -j DROP
        fi

        # Limit Concurrent Connections Per IP
        if [ -n "$MAX_CONN_PER_IP" ] && [ "$MAX_CONN_PER_IP" -gt 0 ]; then
            iptables -A UG_INPUT -p tcp --syn -m connlimit --connlimit-above "$MAX_CONN_PER_IP" --connlimit-mask 32 -j DROP
        fi
    fi

    # 9. Pterodactyl Panel & Wings Integration
    if [ "$PTERODACTYL_MODE" = "true" ]; then
        echo -e "${CYAN}  [+] Pterodactyl Auto-Shield Engine Active:${NC}"
        
        # Preserve Docker Interfaces
        for dev in $DOCKER_INTERFACES; do
            if ip link show "$dev" &>/dev/null; then
                echo -e "      - Preserving Docker Interface: ${GREEN}$dev${NC}"
                iptables -A UG_INPUT -i "$dev" -j ACCEPT
                iptables -A FORWARD -i "$dev" -j ACCEPT
                iptables -A FORWARD -o "$dev" -j ACCEPT
            fi
        done

        # Hook into DOCKER-USER chain
        if iptables -L DOCKER-USER -n &>/dev/null; then
            echo -e "      - Preserving ${GREEN}DOCKER-USER${NC} container mapping chain"
            if ! iptables -C DOCKER-USER -j RETURN 2>/dev/null; then
                iptables -A DOCKER-USER -j RETURN
            fi
        fi

        # Open Pterodactyl Web & Wings core ports
        IFS=',' read -ra WEB_PORTS <<< "$PTERODACTYL_WEB_PORTS"
        for port in "${WEB_PORTS[@]}"; do
            port=$(echo "$port" | xargs)
            [ -n "$port" ] && iptables -A UG_INPUT -p tcp --dport "$port" -j ACCEPT
        done

        IFS=',' read -ra WINGS_PORTS <<< "$PTERODACTYL_WINGS_PORTS"
        for port in "${WINGS_PORTS[@]}"; do
            port=$(echo "$port" | xargs)
            [ -n "$port" ] && iptables -A UG_INPUT -p tcp --dport "$port" -j ACCEPT
            [ -n "$port" ] && iptables -A UG_INPUT -p udp --dport "$port" -j ACCEPT
        done

        # Auto-detect running game containers
        if [ "$AUTO_DETECT_WINGS_ALLOCATIONS" = "true" ] && command -v docker &>/dev/null; then
            echo -e "      - Auto-detecting active container game allocations..."
            ALLOC_PORTS=$(docker ps --format "{{.Ports}}" 2>/dev/null | grep -oP '\d+(?=->)' | sort -u)
            for p in $ALLOC_PORTS; do
                if [ -n "$p" ]; then
                    iptables -A UG_INPUT -p tcp --dport "$p" -j ACCEPT
                    iptables -A UG_INPUT -p udp --dport "$p" -j ACCEPT
                fi
            done
        fi
    fi

    # 10. Open Configured Ports (TCP_IN & UDP_IN)
    if [ -n "$TCP_IN" ]; then
        echo -e "${YELLOW}  [+] Opening Standard TCP Ports: $TCP_IN...${NC}"
        IFS=',' read -ra T_PORTS <<< "$TCP_IN"
        for port in "${T_PORTS[@]}"; do
            port=$(echo "$port" | xargs)
            [ -n "$port" ] && iptables -A UG_INPUT -p tcp --dport "$port" -j ACCEPT
        done
    fi

    if [ -n "$UDP_IN" ]; then
        echo -e "${YELLOW}  [+] Opening Standard UDP Ports: $UDP_IN...${NC}"
        IFS=',' read -ra U_PORTS <<< "$UDP_IN"
        for port in "${U_PORTS[@]}"; do
            port=$(echo "$port" | xargs)
            [ -n "$port" ] && iptables -A UG_INPUT -p udp --dport "$port" -j ACCEPT
        done
    fi

    # 11. Open Port Ranges
    if [ -n "$TCP_PORT_RANGES" ]; then
        echo -e "${YELLOW}  [+] Opening TCP Port Ranges: $TCP_PORT_RANGES...${NC}"
        for range in $TCP_PORT_RANGES; do
            iptables -A UG_INPUT -p tcp --dport "$range" -j ACCEPT
        done
    fi

    if [ -n "$UDP_PORT_RANGES" ]; then
        echo -e "${YELLOW}  [+] Opening UDP Port Ranges: $UDP_PORT_RANGES...${NC}"
        for range in $UDP_PORT_RANGES; do
            iptables -A UG_INPUT -p udp --dport "$range" -j ACCEPT
        done
    fi

    # 12. Logging Dropped Packets
    if [ "$ENABLE_LOGGING" = "true" ]; then
        iptables -A UG_INPUT -m limit --limit "${LOG_LIMIT:-5/m}" -j LOG --log-prefix "${LOG_PREFIX:-[UNIQUE-GUARD-DROP] }" --log-level 4
    fi

    # 13. Set Final Default Policy
    if [ "$DEFAULT_INPUT_POLICY" = "DROP" ]; then
        iptables -A UG_INPUT -j DROP
    fi

    save_rules
    echo -e "${GREEN}${BOLD}[SUCCESS] UNIQUE GUARD is active & protecting your server!${NC}\n"
    send_discord_alert "Firewall Started" "UNIQUE GUARD Firewall rules applied successfully." "3066993"
}

# Stop Firewall
stop_firewall() {
    check_root
    echo -e "${YELLOW}[*] Stopping UNIQUE GUARD Firewall and restoring open policies...${NC}"

    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT

    iptables -D INPUT -j UG_INPUT 2>/dev/null

    iptables -F UG_INPUT 2>/dev/null
    iptables -X UG_INPUT 2>/dev/null
    iptables -F UG_DDOS 2>/dev/null
    iptables -X UG_DDOS 2>/dev/null
    iptables -F UG_LOG 2>/dev/null
    iptables -X UG_LOG 2>/dev/null

    save_rules
    echo -e "${RED}[STATUS] UNIQUE GUARD Firewall stopped.${NC}"
    send_discord_alert "Firewall Stopped" "UNIQUE GUARD Firewall has been deactivated!" "15158332"
}

# Save rules
save_rules() {
    if command -v netfilter-persistent &>/dev/null; then
        netfilter-persistent save &>/dev/null
    elif [ -d "/etc/iptables" ]; then
        iptables-save > /etc/iptables/rules.v4 2>/dev/null
    elif [ -f "/etc/sysconfig/iptables" ]; then
        iptables-save > /etc/sysconfig/iptables 2>/dev/null
    fi
}

# Show Status
show_status() {
    print_banner
    load_config

    echo -e "${BOLD}=== UNIQUE GUARD Firewall Status ===${NC}"
    if iptables -C INPUT -j UG_INPUT 2>/dev/null; then
        echo -e "Status: ${GREEN}${BOLD}ACTIVE (PROTECTED)${NC}"
    else
        echo -e "Status: ${RED}${BOLD}INACTIVE${NC}"
    fi

    echo -e "\n${BOLD}Configuration Summary:${NC}"
    echo -e "  - Anti-DDoS Engine:     ${CYAN}${ENABLE_ANTI_DDOS:-false}${NC}"
    echo -e "  - Pterodactyl Mode:     ${CYAN}${PTERODACTYL_MODE:-false}${NC}"
    echo -e "  - Discord Alerts:       ${CYAN}${ENABLE_DISCORD_ALERTS:-false}${NC}"
    echo -e "  - Allowed TCP Ports:    ${GREEN}${TCP_IN:-None}${NC}"
    echo -e "  - Allowed UDP Ports:    ${GREEN}${UDP_IN:-None}${NC}"
    echo -e "  - UDP Port Ranges:     ${GREEN}${UDP_PORT_RANGES:-None}${NC}"
    echo -e "  - Whitelisted IPs:     ${YELLOW}${WHITELIST_IPS:-None}${NC}"
    echo -e "  - Blacklisted IPs:     ${RED}${BLACKLIST_IPS:-None}${NC}"

    echo -e "\n${BOLD}Active IPTables Chains & Rules:${NC}"
    iptables -L UG_INPUT -v -n --line-numbers 2>/dev/null | head -n 35
    echo ""
}

# Allow a Port
allow_port() {
    check_root
    load_config
    local spec="$1"

    if [ -z "$spec" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard allow <port/proto>${NC}"
        echo -e "Example: uniqueguard allow 25565/udp"
        exit 1
    fi

    local port="${spec%/*}"
    local proto="${spec#*/}"
    proto=$(echo "$proto" | tr '[:upper:]' '[:lower:]')
    [ "$proto" != "tcp" ] && [ "$proto" != "udp" ] && proto="tcp"

    echo -e "${BLUE}[*] Allowing port $port ($proto)...${NC}"
    iptables -I UG_INPUT 1 -p "$proto" --dport "$port" -j ACCEPT
    save_rules

    # Persist in config file
    if [ "$proto" = "tcp" ]; then
        sed -i "s/TCP_IN=\"/TCP_IN=\"$port,/g" "$CONFIG_FILE" 2>/dev/null || true
    else
        sed -i "s/UDP_IN=\"/UDP_IN=\"$port,/g" "$CONFIG_FILE" 2>/dev/null || true
    fi

    echo -e "${GREEN}[SUCCESS] Port $port/$proto allowed successfully!${NC}"
}

# Deny a Port
deny_port() {
    check_root
    local spec="$1"

    if [ -z "$spec" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard deny <port/proto>${NC}"
        exit 1
    fi

    local port="${spec%/*}"
    local proto="${spec#*/}"
    proto=$(echo "$proto" | tr '[:upper:]' '[:lower:]')
    [ "$proto" != "tcp" ] && [ "$proto" != "udp" ] && proto="tcp"

    echo -e "${YELLOW}[*] Removing allowed port rule for $port ($proto)...${NC}"
    iptables -D UG_INPUT -p "$proto" --dport "$port" -j ACCEPT 2>/dev/null
    save_rules

    echo -e "${GREEN}[SUCCESS] Port $port/$proto rule removed.${NC}"
}

# Block an IP
block_ip() {
    check_root
    local ip="$1"

    if [ -z "$ip" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard block <IP>${NC}"
        exit 1
    fi

    echo -e "${RED}[*] Blocking IP address $ip...${NC}"
    iptables -I UG_INPUT 1 -s "$ip" -j DROP
    save_rules
    send_discord_alert "IP Blocked" "IP Address \`${ip}\` was blocked." "15158332"

    echo -e "${GREEN}[SUCCESS] IP $ip has been blocked.${NC}"
}

# Unblock an IP
unblock_ip() {
    check_root
    local ip="$1"

    if [ -z "$ip" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard unblock <IP>${NC}"
        exit 1
    fi

    echo -e "${YELLOW}[*] Unblocking IP address $ip...${NC}"
    iptables -D UG_INPUT -s "$ip" -j DROP 2>/dev/null
    save_rules

    echo -e "${GREEN}[SUCCESS] IP $ip has been unblocked.${NC}"
}

# Apply Pre-built Service Profiles
apply_profile() {
    check_root
    load_config
    local profile="$1"

    if [ -z "$profile" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard profile <name>${NC}"
        echo -e "Available profiles: ${YELLOW}minecraft, rust, fivem, samp, csgo, web, database${NC}"
        exit 1
    fi

    case "$profile" in
        minecraft)
            echo -e "${BLUE}[*] Applying Minecraft Profile (25565/tcp, 25565/udp, 25575/tcp RCON, 8123/tcp Dynmap)...${NC}"
            allow_port "25565/tcp"
            allow_port "25565/udp"
            allow_port "25575/tcp"
            allow_port "8123/tcp"
            ;;
        rust)
            echo -e "${BLUE}[*] Applying Rust Server Profile (28015/udp, 28016/tcp RCON, 28082/tcp App)...${NC}"
            allow_port "28015/udp"
            allow_port "28016/tcp"
            allow_port "28082/tcp"
            ;;
        fivem)
            echo -e "${BLUE}[*] Applying FiveM Profile (30120/tcp, 30120/udp, 40120/tcp txAdmin)...${NC}"
            allow_port "30120/tcp"
            allow_port "30120/udp"
            allow_port "40120/tcp"
            ;;
        samp)
            echo -e "${BLUE}[*] Applying SA-MP Profile (7777/udp)...${NC}"
            allow_port "7777/udp"
            ;;
        csgo|cs2)
            echo -e "${BLUE}[*] Applying CS:GO / CS2 Profile (27015/tcp, 27015/udp, 27020/udp GOTV)...${NC}"
            allow_port "27015/tcp"
            allow_port "27015/udp"
            allow_port "27020/udp"
            ;;
        web)
            echo -e "${BLUE}[*] Applying Web Server Profile (80/tcp HTTP, 443/tcp HTTPS)...${NC}"
            allow_port "80/tcp"
            allow_port "443/tcp"
            ;;
        database)
            echo -e "${BLUE}[*] Applying Database Profile (3306/tcp MySQL, 5432/tcp Postgres, 6379/tcp Redis)...${NC}"
            allow_port "3306/tcp"
            allow_port "5432/tcp"
            allow_port "6379/tcp"
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown profile: $profile${NC}"
            echo -e "Available profiles: minecraft, rust, fivem, samp, csgo, web, database"
            exit 1
            ;;
    esac
}

# Live Network & Attack Monitor
monitor_network() {
    check_root
    echo -e "${CYAN}${BOLD}=== UNIQUE GUARD Live Network & Attack Monitor ===${NC}"
    echo -e "Press ${YELLOW}Ctrl+C${NC} to exit.\n"

    while true; do
        clear
        print_banner
        echo -e "${BOLD}Active Connections Summary:${NC}"
        ss -s 2>/dev/null || netstat -sw 2>/dev/null
        echo -e "\n${BOLD}Top 10 Connecting IPs:${NC}"
        ss -ntu 2>/dev/null | awk '{print $5}' | cut -d: -f1 | sort | uniq -c | sort -nr | head -n 10
        echo -e "\n${BOLD}Recent Dropped Attack Packets (Last 5):${NC}"
        if command -v journalctl &>/dev/null; then
            journalctl -k | grep "UNIQUE-GUARD-DROP" | tail -n 5
        else
            dmesg | grep "UNIQUE-GUARD-DROP" | tail -n 5
        fi
        sleep 3
    done
}

# Security Audit Tool
security_audit() {
    print_banner
    check_root
    load_config

    echo -e "${CYAN}${BOLD}=== UNIQUE GUARD VPS/VDS Security Audit Report ===${NC}\n"
    local score=100

    # 1. Firewall active check
    if iptables -C INPUT -j UG_INPUT 2>/dev/null; then
        echo -e "  [✓] UNIQUE GUARD Firewall: ${GREEN}Active (+30 pts)${NC}"
    else
        echo -e "  [✗] UNIQUE GUARD Firewall: ${RED}Inactive (-30 pts)${NC}"
        score=$((score - 30))
    fi

    # 2. Anti-DDoS check
    if [ "$ENABLE_ANTI_DDOS" = "true" ]; then
        echo -e "  [✓] Anti-DDoS Engine: ${GREEN}Enabled (+20 pts)${NC}"
    else
        echo -e "  [✗] Anti-DDoS Engine: ${RED}Disabled (-20 pts)${NC}"
        score=$((score - 20))
    fi

    # 3. Pterodactyl mode check
    if [ "$PTERODACTYL_MODE" = "true" ]; then
        echo -e "  [✓] Pterodactyl Container Isolation: ${GREEN}Active (+20 pts)${NC}"
    else
        echo -e "  [!] Pterodactyl Mode: ${YELLOW}Disabled${NC}"
    fi

    # 4. Fail2ban check
    if systemctl is-active fail2ban &>/dev/null; then
        echo -e "  [✓] Fail2ban SSH/Panel Defense: ${GREEN}Active (+15 pts)${NC}"
    else
        echo -e "  [✗] Fail2ban Defense: ${RED}Not Running (-15 pts)${NC}"
        score=$((score - 15))
    fi

    # 5. Default Policy check
    if [ "$DEFAULT_INPUT_POLICY" = "DROP" ]; then
        echo -e "  [✓] Default INPUT Policy: ${GREEN}DROP (+15 pts)${NC}"
    else
        echo -e "  [✗] Default INPUT Policy: ${RED}ACCEPT (-15 pts)${NC}"
        score=$((score - 15))
    fi

    echo -e "\n${BOLD}Final Security Audit Score: ${score}/100${NC}"
    if [ "$score" -ge 80 ]; then
        echo -e "Status: ${GREEN}${BOLD}EXCELLENT HARDENING${NC}\n"
    elif [ "$score" -ge 50 ]; then
        echo -e "Status: ${YELLOW}${BOLD}MODERATE SECURITY (Action Required)${NC}\n"
    else
        echo -e "Status: ${RED}${BOLD}CRITICAL VULNERABILITY RISK${NC}\n"
    fi
}

# Backup & Restore Logic
backup_rules() {
    check_root
    load_config
    local backup_dir="${BACKUP_DIR:-/var/backups/uniqueguard}"
    mkdir -p "$backup_dir"
    local timestamp=$(date +'%Y%m%d_%H%M%S')
    local file="${backup_dir}/uniqueguard_backup_${timestamp}.tar.gz"

    tar -czf "$file" "$CONFIG_FILE" /etc/systemd/system/uniqueguard.service 2>/dev/null || true
    echo -e "${GREEN}[SUCCESS] Backup saved to ${file}${NC}"
}

restore_rules() {
    check_root
    local file="$1"
    if [ -z "$file" ] || [ ! -f "$file" ]; then
        echo -e "${RED}[ERROR] Usage: uniqueguard restore <path-to-backup.tar.gz>${NC}"
        exit 1
    fi
    tar -xzf "$file" -C / 2>/dev/null
    echo -e "${GREEN}[SUCCESS] Configuration restored from ${file}${NC}"
    start_firewall
}

# Interactive Pterodactyl Setup
setup_pterodactyl() {
    print_banner
    check_root
    load_config

    echo -e "${CYAN}${BOLD}=== UNIQUE GUARD Pterodactyl Auto-Configuration Wizard ===${NC}\n"
    echo -e "This wizard configures complete protection for Pterodactyl Panel & Wings nodes."
    echo -e "It opens Web Panel (80/443), Wings API (8080), Wings SFTP (2022), and game bridges.\n"

    sed -i 's/PTERODACTYL_MODE=".*"/PTERODACTYL_MODE="true"/' "$CONFIG_FILE" 2>/dev/null

    read -rp "Enter Game Allocation Port Range (Default: 25565:25600 27015:27050): " user_ranges
    if [ -n "$user_ranges" ]; then
        sed -i "s/UDP_PORT_RANGES=\".*\"/UDP_PORT_RANGES=\"$user_ranges\"/" "$CONFIG_FILE" 2>/dev/null
        sed -i "s/TCP_PORT_RANGES=\".*\"/TCP_PORT_RANGES=\"$user_ranges\"/" "$CONFIG_FILE" 2>/dev/null
    fi

    echo -e "\n${GREEN}[+] Pterodactyl configurations updated.${NC}"
    echo -e "${BLUE}[*] Restarting UNIQUE GUARD firewall...${NC}"
    start_firewall
}

# View Logs
show_logs() {
    check_root
    echo -e "${CYAN}${BOLD}=== Recent UNIQUE GUARD Dropped Packet Logs ===${NC}\n"
    if command -v journalctl &>/dev/null; then
        journalctl -k | grep "UNIQUE-GUARD-DROP" | tail -n 30
    else
        dmesg | grep "UNIQUE-GUARD-DROP" | tail -n 30
    fi
}

# Display Help
show_help() {
    print_banner
    echo -e "${BOLD}Usage:${NC} uniqueguard [command] [options]\n"
    echo -e "${BOLD}Core Commands:${NC}"
    echo -e "  ${GREEN}start${NC}                  Start & apply firewall and Anti-DDoS rules"
    echo -e "  ${GREEN}stop${NC}                   Stop firewall and restore open network policies"
    echo -e "  ${GREEN}restart | reload${NC}       Reload firewall rules from config file"
    echo -e "  ${GREEN}status${NC}                 Display active firewall status and statistics"
    echo -e "  ${GREEN}allow <port/proto>${NC}     Allow a specific port (e.g. 25565/udp, 8080/tcp)"
    echo -e "  ${GREEN}deny <port/proto>${NC}      Remove allowed rule for a port"
    echo -e "  ${GREEN}block <IP>${NC}             Immediately block an IP address"
    echo -e "  ${GREEN}unblock <IP>${NC}           Remove IP from blacklist"
    echo -e "  ${GREEN}profile <name>${NC}         Apply server profiles (minecraft, rust, fivem, csgo, web, database)"
    echo -e "  ${GREEN}setup-pterodactyl${NC}      Run automated Pterodactyl Panel/Wings wizard"
    echo -e "  ${GREEN}monitor${NC}                Launch real-time connection & attack dashboard"
    echo -e "  ${GREEN}audit${NC}                  Run VPS security audit & hardening report"
    echo -e "  ${GREEN}backup${NC}                 Backup firewall configuration"
    echo -e "  ${GREEN}restore <file>${NC}         Restore firewall configuration from backup archive"
    echo -e "  ${GREEN}logs${NC}                   View recent dropped attack connection logs"
    echo -e "  ${GREEN}help${NC}                   Show this menu\n"
}

# Router
case "$1" in
    start)
        start_firewall
        ;;
    stop)
        stop_firewall
        ;;
    restart|reload)
        start_firewall
        ;;
    status)
        show_status
        ;;
    allow)
        allow_port "$2"
        ;;
    deny)
        deny_port "$2"
        ;;
    block)
        block_ip "$2"
        ;;
    unblock)
        unblock_ip "$2"
        ;;
    profile)
        apply_profile "$2"
        ;;
    monitor)
        monitor_network
        ;;
    audit)
        security_audit
        ;;
    backup)
        backup_rules
        ;;
    restore)
        restore_rules "$2"
        ;;
    setup-pterodactyl)
        setup_pterodactyl
        ;;
    logs)
        show_logs
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        if [ -z "$1" ]; then
            show_help
        else
            echo -e "${RED}[ERROR] Unknown command: $1${NC}"
            echo -e "Run ${YELLOW}uniqueguard help${NC} to see available commands."
            exit 1
        fi
        ;;
esac
